# cinaauth API host (auth.cinagroup.com) — session check + admin API calls.
CINAUTH_BASE_URL=https://auth.cinagroup.com
# cinaauth frontend host (demo-auth.cinagroup.com) — login/sign-out redirects.
CINAUTH_AUTH_URL=https://demo-auth.cinagroup.com
CINAUTH_ADMIN_SERVICE_KEY=replace-with-cloudflare-pages-secret

# Admin role whitelist (comma-separated)
CINAADMIN_ALLOWED_ROLES=super_admin,security_admin

# Public (shipped to client)
NEXT_PUBLIC_APP_NAME=CinaGroup Admin
NEXT_PUBLIC_CINAUTH_BASE_URL=https://auth.cinagroup.com
NEXT_PUBLIC_CINAUTH_AUTH_URL=https://demo-auth.cinagroup.com
